rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: messages
    // Document ID: auto-generated
    // Fields:
    //   - text: string (required, 1-500 chars) - message content
    //   - userId: string (required) - sender UID
    //   - userName: string (required, 1-50 chars) - sender display name
    //   - timestamp: timestamp (required) - server time
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['text', 'userId', 'userName', 'timestamp']) &&
             data.keys().hasOnly(['text', 'userId', 'userName', 'timestamp']) &&
             data.text is string && data.text.size() >= 1 && data.text.size() <= 500 &&
             data.userId is string && data.userId == request.auth.uid &&
             data.userName is string && data.userName.size() >= 1 && data.userName.size() <= 50 &&
             data.timestamp is timestamp;
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidMessage(request.resource.data);
      allow update, delete: if false; // Messages are immutable for now
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
